          "gender": "masculine",
          "number": "singular"
        },
        "context_rules": "Edificio del [[kerbal_space_center]] in cui vengono assemblati aerei e spazioplani."
      },
      "ksc_sph": {
        "term": "SPH",
        "class": "noun.acronym",
