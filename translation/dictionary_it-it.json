        "grammar": {
          "gender": "masculine"
        },
        "refers_to": "ksc_SpaceplaneHangar"
      },
      "ksc_LaunchPad": {
        "term": "Launch Pad",
        "class": "noun.proper",
        "translation": "piattaforma di lancio",
        "grammar": {
          "gender": "feminine",
          "number": "singular"
        },
        "context_rules": "Luogo del [[kerbal_space_center]] da cui vengono lanciato i razzi. Tratta come 'noun.common' se nel testo originale compare in minuscolo. Traduci sempre e comunque con iniziali minuscole."
      },
      "ksc_Runaway": {
        "term": "Runaway",
        "class": "noun.proper",
        "translation": "pista",
        "grammar": {
          "gender": "feminine",
          "number": "singular"
        },
        "context_rules": "Luogo del [[kerbal_space_center]] su cui decollano e/o atterrano aerei e spazioplani. Tratta come 'noun.common' se nel testo originale compare in minuscolo. Traduci sempre e comunque con iniziali minuscole."
      },
      "ksc_TrackingStation": {
        "term": "Tracking Station",
        "class": "noun.proper",
        "translation": "stazione di tracciamento",
        "grammar": {
          "gender": "masculine",
          "number": "singular"
        },
        "context_rules": "Edificio del [[kerbal_space_center]] da cui vengono monitorate tutte le missiono attive."
      },
      "ksc_AstronautComplex": {
        "term": "Astronaut Complex",
        "class": "noun.proper",
        "translation": "complesso degli astronauti",
        "grammar": {
          "gender": "masculine",
          "number": "singular"
        },
        "context_rules": "Edificio del [[kerbal_space_center]], centro di addestramento e residenza dei [[kerbonaut]]. Traduci sempre con iniziali maiuscole."
      },
      "ksc_ResearchAndDevelopment": {
        "term": "Research and Development",
        "class": "noun.proper",
        "translation": "Ricerca e Sviluppo",
        "grammar": {
          "gender": "feminine",
          "number": "singular"
        },
        "context_rules": "Edificio e dipartimento del [[kerbal_space_center]] dove vengono analizzati i risultati degli esperimenti e sviluppate nuove tecnologie. Traduci sempre con iniziali maiuscole."
      },
      "ksc_RnD": {
        "term": "R&D",
        "class": "noun.acronym",
        "translation": "R&S",
        "grammar": {
          "gender": "feminine"
        },
        "refers_to": "ksc_ResearchAndDevelopment"
      },
      "ksc_Crawlerway": {
        "term": "Crawlerway",
        "class": "noun.proper",
        "translation": "pista di trasporto",
        "grammar": {
          "gender": "feminine",
          "number": "singular"
        },
        "context_rules": "Pista del [[kerbal_space_center]] su cui vengono trasportati i veicoli assemblati nel [[ksc_VehicleAssembyBuilding]] fino alla [[ksc_LaunchPad]]."
      }
