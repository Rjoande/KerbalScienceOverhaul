        "translation": "Centro Spaziale Kerbal",
        "grammar": {
          "gender": "masculine",
          "number": "singular"
        },
        "context_rules": "Sede del programma spaziale su Kerbin. Tradurre sempre con iniziali maiuscole."
      },
      "ksc": {
        "term": "KSC",
