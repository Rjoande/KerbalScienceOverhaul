    "technical_terms": {
      "kerbal": {
        "term": "kerbal",
        "class": "noun.common",
        "is_adjective_capable": true,
        "translation": "kerbal",
        "grammar": {
          "gender": "neuter",
          "number_flexion": {
            "singular": "kerbal",
            "plural": "kerbal"
          },
          "is_epicene": true,
          "notes": "Invariabile in genere e in numero. Non aggiungere mai 's' o desinenze italiane. Traduci sempre con l'iniziale minuscola."
        },
        "context_rules": "Umanoidi verdi originari del pianeta Kerbin. Può riferirsi ai singoli individui, alla specie intera, o come aggettivo."
      },
      "kerbonaut": {
        "term": "kerbonaut",
        "class": "noun.common",
        "is_adjective_capable": false,
        "translation": "kerbonauta",
        "grammar": {
          "gender": "neuter",
          "number_flexion": {
            "singular": "kerbonauta",
            "plural": "kerbonauti"
          },
          "is_epicene": true
        },
        "context_rules": "Sinonimo di 'astronauta'. Un [[kerbal]] astronauta."
      },
